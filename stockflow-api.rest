### ===== MOVEMENTS ENDPOINTS =====

### Get all movements
GET {{baseUrl}}/movements
Authorization: {{authToken}}

### Record opening stock for all Products
POST {{baseUrl}}/movements/opening
Content-Type: application/json
Authorization: {{authToken}}

{
  "products": [
    {"product_id": 1, "qty": 50},
    {"product_id": 2, "qty": 30},
    {"product_id": 3, "qty": 25}
  ]
}

### Try to record opening stock again for same Product (should fail)
POST {{baseUrl}}/movements/opening
Content-Type: application/json
Authorization: {{authToken}}

{
  "products": [
    {"product_id": 1, "qty": 10}
  ]
}

### Record goods receipt
POST {{baseUrl}}/movements/receipt
Content-Type: application/json
Authorization: {{authToken}}

{
  "products": [
    {"product_id": 1, "qty": 20},
    {"product_id": 2, "qty": 15}
  ],
  "note": "Morning delivery from warehouse"
}

### Try to record receipt again same day (should fail)
POST {{baseUrl}}/movements/receipt
Content-Type: application/json
Authorization: {{authToken}}

{
  "products": [
    {"product_id": 1, "qty": 5}
  ]
}

### Distribute to Shop A
POST {{baseUrl}}/movements/distribution
Content-Type: application/json
Authorization: {{authToken}}

{
  "shop_id": 1,
  "products": [
    {"product_id": 1, "qty": 15, "selling_price": 6000},
    {"product_id": 2, "qty": 10, "selling_price": 6500}
  ],
  "note": "Afternoon delivery"
}

### Try to distribute more than available balance (should fail)
POST {{baseUrl}}/movements/distribution
Content-Type: application/json
Authorization: {{authToken}}

{
  "shop_id": 1,
  "products": [
    {"product_id": 1, "qty": 100}
  ]
}

### Record correction entry
POST {{baseUrl}}/movements/correction
Content-Type: application/json
Authorization: {{authToken}}

{
  "product_id": 1,
  "qty": -2,
  "shop_id": 1,
  "note": "Found 2 damaged cartons during inventory check"
}

### Record spoil (pending)
POST {{baseUrl}}/movements/spoil
Content-Type: application/json
Authorization: {{authToken}}

{
  "product_id": 1,
  "qty": 3,
  "reason": "damaged",
  "note": "Broken during transport"
}

### Record another spoil (expired)
POST {{baseUrl}}/movements/spoil
Content-Type: application/json
Authorization: {{authToken}}

{
  "product_id": 2,
  "qty": 2,
  "reason": "expired",
  "note": "Past expiry date"
}

### Record third spoil (returned)
POST {{baseUrl}}/movements/spoil
Content-Type: application/json
Authorization: {{authToken}}

{
  "product_id": 3,
  "qty": 1,
  "reason": "returned",
  "note": "Customer returned damaged product"
}

### Get pending spoils
GET {{baseUrl}}/movements?status=pending
Authorization: {{authToken}}

### Confirm a spoil
PUT {{baseUrl}}/movements/spoil/1/confirm
Authorization: {{authToken}}

### Reject a spoil
PUT {{baseUrl}}/movements/spoil/2/reject
Authorization: {{authToken}}

### Get all movements after confirm/reject
GET {{baseUrl}}/movements
Authorization: {{authToken}}

### Filter movements by type
GET {{baseUrl}}/movements?type=distribution
Authorization: {{authToken}}

### Filter movements by Product
GET {{baseUrl}}/movements?product_id=1
Authorization: {{authToken}}

### Filter movements by shop
GET {{baseUrl}}/movements?shop_id=1
Authorization: {{authToken}}

### Filter movements by date range
GET {{baseUrl}}/movements?from=2026-03-04&to=2026-03-04
Authorization: {{authToken}}

